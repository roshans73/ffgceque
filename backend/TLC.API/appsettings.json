{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=tlc_management.db"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "your-tenant-id",
    "ClientId": "your-client-id"
  },
  "Jwt": {
    "Key": "REPLACE-WITH-A-STRONG-SECRET-AT-LEAST-32-CHARS-LONG",
    "Issuer": "TLC.API",
    "Audience": "TLC.Client",
    "ExpiryMinutes": "480"
  },
  "CorsOrigins": [
    "http://localhost:3000",
    "http://localhost:5173",
    "https://yourdomain.com"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*"
}